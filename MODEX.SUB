' =============================================================================
' MODEX Drawing Primitives - Optimized for Mode-X planar architecture
' =============================================================================

' =============================================================================
' Draw line between two points in Mode-X
' Parameters:
'   X1, Y1 - Starting point coordinates (BYVAL)
'   X2, Y2 - Ending point coordinates (BYVAL)
'   colorVal - Line colorVal (BYVAL)
' Returns: Nothing
' Note: Optimized for Mode-X with special cases for horizontal/vertical lines
' =============================================================================
SUB ModeX_LineDraw(X1_a AS WORD, Y1_a AS WORD, X2_a AS WORD, Y2_a AS WORD, colorVal_a AS BYTE)
    DIM X1 AS WORD, Y1 AS WORD, X2 AS WORD, Y2 AS WORD, colorVal AS BYTE
    X1 = X1_a : Y1 = Y1_a : X2 = X2_a : Y2 = Y2_a : colorVal = colorVal_a
    ' Check for horizontal line
    IF Y1 = Y2 THEN
        CALL ModeX_HLine(X1, X2, Y1, colorVal)
        EXIT SUB
    END IF

    ' Check for vertical line
    IF X1 = X2 THEN
        CALL ModeX_VLine(X1, Y1, Y2, colorVal)
        EXIT SUB
    END IF

    ' Diagonal line - use optimized Bresenham's algorithm
    DIM DeltaX AS INTEGER, DeltaY AS INTEGER, StepX AS INTEGER, StepY AS INTEGER
    DIM ErrorTerm AS INTEGER, CurrentX AS WORD, CurrentY AS WORD
    DIM PlaneNumber AS BYTE, ByteOffset AS WORD, BitMask AS BYTE

    ' Calculate deltas and step directions
    DeltaX = ABS(X2 - X1)
    DeltaY = ABS(Y2 - Y1)

    IF X1 < X2 THEN StepX = 1 ELSE StepX = -1
    IF Y1 < Y2 THEN StepY = 1 ELSE StepY = -1

    ' Initialize error term
    ErrorTerm = DeltaX - DeltaY

    ' Set starting position
    CurrentX = X1
    CurrentY = Y1

    ' Draw line using Bresenham's algorithm with Mode-X optimizations
    DO
        ' Calculate plane and offset for current pixel using fast assembly
        PlaneNumber = CurrentX AND 3

        ' Ultra-fast CurrentX/4 using bit shift
        !MOV AX, CurrentX
        !SHR AX, 1 ; Divide by 4
        !SHR AX, 1
        !MOV BX, AX             ; Store CurrentX/4

        ByteOffset = CurrentY * ModeXSystemContext.LogicalWidth + (CurrentX \ 4)
        BitMask = PlaneMaskTable(PlaneNumber)

        ' Set plane select register
        mxPlane = 1
        SHIFT LEFT mxPlane, 0
    !MOV DX, &H3C4          ; Sequencer Address Register
        !MOV AL, 2              ; Map Mask Register
        !OUT DX, AL
        !INC DX                 ; Sequencer dataBuf Register
        !MOV AL, BitMask
        !OUT DX, AL

        ' Write pixel to VGA memory
        !PUSH ES
        !MOV AX, &HA000
        !MOV ES, AX
        !MOV BX, ByteOffset
        !MOV AL, colorVal
        !MOV ES:[BX], AL
        !POP ES

        ' Check if we've reached the end point
        IF CurrentX = X2 AND CurrentY = Y2 THEN EXIT DO

        ' Calculate next point
        DIM Error2 AS INTEGER
        Error2 = ErrorTerm * 2

        IF Error2 > -DeltaY THEN
            ErrorTerm = ErrorTerm - DeltaY
            CurrentX = CurrentX + StepX
        END IF

        IF Error2 < DeltaX THEN
            ErrorTerm = ErrorTerm + DeltaX
            CurrentY = CurrentY + StepY
        END IF
    LOOP
END SUB

' =============================================================================
' Draw filled rectangle in Mode-X
' Parameters:
'   X1, Y1 - Top-leftV corner (BYVAL)
'   X2, Y2 - Bottom-rightV corner (BYVAL)
'   colorVal - Fill colorVal (BYVAL)
' Returns: Nothing
' Note: Highly optimized for Mode-X planar architecture
' =============================================================================
SUB ModeX_FillRect(X1_a AS WORD, Y1_a AS WORD, X2_a AS WORD, Y2_a AS WORD, colorVal_a AS BYTE)
    DIM X1 AS WORD, Y1 AS WORD, X2 AS WORD, Y2 AS WORD, colorVal AS BYTE
    X1 = X1_a : Y1 = Y1_a : X2 = X2_a : Y2 = Y2_a : colorVal = colorVal_a
    DIM ScanLine AS WORD

    ' Ensure coordinates are ordered
    IF X1 > X2 THEN SWAP X1, X2
    IF Y1 > Y2 THEN SWAP Y1, Y2

    ' Use optimized horizontal line drawing for each scanline
    FOR ScanLine = Y1 TO Y2
        CALL ModeX_HLine(X1, X2, ScanLine, colorVal)
    NEXT ScanLine
END SUB

' =============================================================================
' Draw rectangle outline in Mode-X
' Parameters:
'   X1, Y1 - Top-leftV corner (BYVAL)
'   X2, Y2 - Bottom-rightV corner (BYVAL)
'   colorVal - Border colorVal (BYVAL)
' Returns: Nothing
' =============================================================================
SUB ModeX_DrawRect(X1_a AS WORD, Y1_a AS WORD, X2_a AS WORD, Y2_a AS WORD, colorVal_a AS BYTE)
    DIM X1 AS WORD, Y1 AS WORD, X2 AS WORD, Y2 AS WORD, colorVal AS BYTE
    X1 = X1_a : Y1 = Y1_a : X2 = X2_a : Y2 = Y2_a : colorVal = colorVal_a
    ' Ensure coordinates are ordered
    IF X1 > X2 THEN SWAP X1, X2
    IF Y1 > Y2 THEN SWAP Y1, Y2

    ' Draw four sides using optimized line routines
    CALL ModeX_HLine(X1, X2, Y1, colorVal)  ' Top
    CALL ModeX_HLine(X1, X2, Y2, colorVal)  ' Bottom
    CALL ModeX_VLine(X1, Y1, Y2, colorVal)  ' leftV
    CALL ModeX_VLine(X2, Y1, Y2, colorVal)  ' rightV
END SUB

' =============================================================================
' Draw circle in Mode-X using midpoint algorithm
' Parameters:
'   CenterX, CenterY - Center coordinates (BYVAL)
'   Radius - Circle radius (BYVAL)
'   colorVal - Circle colorVal (BYVAL)
' Returns: Nothing
' Note: Optimized for Mode-X with symmetry exploitation
' =============================================================================
SUB ModeX_DrawCircle(centerX_a AS WORD, centerY_a AS WORD, radius_a AS WORD, colorVal_a AS BYTE)
    DIM centerX AS WORD, centerY AS WORD, radius AS WORD, colorVal AS BYTE
    centerX = centerX_a : centerY = centerY_a : radius = radius_a : colorVal = colorVal_a
    DIM X AS INTEGER, Y AS INTEGER, DecisionParam AS INTEGER

    X = 0
    Y = Radius
    DecisionParam = 1 - Radius

    ' Draw initial points
    CALL ModeX_PutPixel(CenterX, CenterY + Radius, colorVal)
    CALL ModeX_PutPixel(CenterX, CenterY - Radius, colorVal)
    CALL ModeX_PutPixel(CenterX + Radius, CenterY, colorVal)
    CALL ModeX_PutPixel(CenterX - Radius, CenterY, colorVal)

    ' Draw circle using midpoint algorithm
    DO WHILE X < Y
        X = X + 1

        IF DecisionParam < 0 THEN
            DecisionParam = DecisionParam + 2 * X + 1
        ELSE
            Y = Y - 1
            DecisionParam = DecisionParam + 2 * (X - Y) + 1
        END IF

        ' Draw 8 symmetric points
        CALL ModeX_PutPixel(CenterX + X, CenterY + Y, colorVal)
        CALL ModeX_PutPixel(CenterX - X, CenterY + Y, colorVal)
        CALL ModeX_PutPixel(CenterX + X, CenterY - Y, colorVal)
        CALL ModeX_PutPixel(CenterX - X, CenterY - Y, colorVal)
        CALL ModeX_PutPixel(CenterX + Y, CenterY + X, colorVal)
        CALL ModeX_PutPixel(CenterX - Y, CenterY + X, colorVal)
        CALL ModeX_PutPixel(CenterX + Y, CenterY - X, colorVal)
        CALL ModeX_PutPixel(CenterX - Y, CenterY - X, colorVal)
    LOOP
END SUB

' =============================================================================
' Draw filled circle in Mode-X
' Parameters:
'   CenterX, CenterY - Center coordinates (BYVAL)
'   Radius - Circle radius (BYVAL)
'   colorVal - Fill colorVal (BYVAL)
' Returns: Nothing
' Note: Uses horizontal line fills for efficiency
' =============================================================================
SUB ModeX_FillCircle(centerX_a AS WORD, centerY_a AS WORD, radius_a AS WORD, colorVal_a AS BYTE)
    DIM centerX AS WORD, centerY AS WORD, radius AS WORD, colorVal AS BYTE
    centerX = centerX_a : centerY = centerY_a : radius = radius_a : colorVal = colorVal_a
    DIM X AS INTEGER, Y AS INTEGER, DecisionParam AS INTEGER
    DIM PrevY AS INTEGER

    X = 0
    Y = Radius
    DecisionParam = 1 - Radius
    PrevY = Y

    ' Draw initial horizontal line
    CALL ModeX_HLine(CenterX - Radius, CenterX + Radius, CenterY, colorVal)

    ' Fill circle using horizontal lines
    DO WHILE X < Y
        X = X + 1

        IF DecisionParam < 0 THEN
            DecisionParam = DecisionParam + 2 * X + 1
        ELSE
            ' Y changed, draw horizontal lines for previous Y
            IF Y <> PrevY THEN
                CALL ModeX_HLine(CenterX - X + 1, CenterX + X - 1, CenterY + PrevY, colorVal)
                CALL ModeX_HLine(CenterX - X + 1, CenterX + X - 1, CenterY - PrevY, colorVal)
                PrevY = Y
            END IF

            Y = Y - 1
            DecisionParam = DecisionParam + 2 * (X - Y) + 1
        END IF

        ' Draw horizontal lines for current positions
        CALL ModeX_HLine(CenterX - Y, CenterX + Y, CenterY + X, colorVal)
        CALL ModeX_HLine(CenterX - Y, CenterX + Y, CenterY - X, colorVal)
    LOOP

    ' Draw final lines if Y changed
    IF Y <> PrevY THEN
        CALL ModeX_HLine(CenterX - X, CenterX + X, CenterY + Y, colorVal)
        CALL ModeX_HLine(CenterX - X, CenterX + X, CenterY - Y, colorVal)
    END IF
END SUB

' =============================================================================
' Fast screen-to-screen copy in Mode-X
' Parameters:
'   SrcPage - Source page number (BYVAL)
'   DestPage - Destination page number (BYVAL)
' Returns: Nothing
' Note: Copies entire pages for double buffering
' =============================================================================
SUB ModeX_CopyPage(BYVAL srcPage AS BYTE, BYVAL destPage AS BYTE)
    DIM SrcOffset AS WORD, DestOffset AS WORD
    DIM PlaneNum AS BYTE

    SrcOffset = SrcPage * ModeXSystemContext.PageSize
    DestOffset = DestPage * ModeXSystemContext.PageSize

    ' Copy each plane separately
    FOR PlaneNum = 0 TO 3
        ' Set read plane
        !MOV DX, &H3CE          ; Graphics Controller Address
        !MOV AL, 4              ; Read Map Select Register
        !OUT DX, AL
        !INC DX                 ; Graphics Controller dataBuf
        !MOV AL, PlaneNum
        !OUT DX, AL

        ' Set write plane
    !MOV DX, &H3C4          ; Sequencer Address Register
        !MOV AL, 2              ; Map Mask Register
        !OUT DX, AL
        !INC DX                 ; Sequencer dataBuf Register
        !MOV AL, 1
        !MOV CL, PlaneNum
        !SHL AL, CL             ; Create plane mask
        !OUT DX, AL

        ' Copy this plane
        mxPgSz = ModeXSystemContext.PageSize
        !PUSH ES
        !PUSH DS
        !MOV AX, &HA000
        !MOV ES, AX
        !MOV DS, AX
        !MOV SI, SrcOffset
        !MOV DI, DestOffset
        !MOV CX, mxPgSz
        !SHR CX, 1 ; Divide by 4 for planes
        !SHR CX, 1
        !CLD

        ' 8086-compatible copy loop
        CopyPageLoop:
        !LODSB                  ; Load from DS:SI into AL
        !STOSB                  ; Store AL to ES:DI
        !LOOP CopyPageLoop

        !POP DS
        !POP ES
    NEXT PlaneNum
END SUB

