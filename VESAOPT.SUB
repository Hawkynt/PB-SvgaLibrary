' wire the matching width family into SVGADispatch (from the VESA case)
SUB Svga_WireVesaOptimized
    SELECT CASE SVGAScreenContext.XRes
        CASE 320
            SVGADispatch.PutPixel = CODEPTR32(Vesa320_PutPixel)
            SVGADispatch.GetPixel = CODEPTR32(Vesa320_GetPixel)
            SVGADispatch.HLine = CODEPTR32(Vesa320_HLine)
            SVGADispatch.VLine = CODEPTR32(Vesa320_VLine)
            SVGADispatch.FillRect = CODEPTR32(Vesa320_FillRect)
            SVGADispatch.DrawRect = CODEPTR32(Vesa320_DrawRect)
            SVGADispatch.FillCircle = CODEPTR32(Vesa320_FillCircle)
        CASE 640
            SVGADispatch.PutPixel = CODEPTR32(Vesa640_PutPixel)
