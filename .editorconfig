# Baseline editorconfig — see https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{SUB,BAS,INC,tst}]
indent_size = 4                    # matches the existing PowerBASIC sources

[*.{md,markdown}]
trim_trailing_whitespace = false   # trailing spaces are hard line-breaks
