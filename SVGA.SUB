' =============================================================================
' Generic circle drawing using PUTPIXEL (for modes without optimized circles)
' =============================================================================
SUB Svga_DrawCircleGeneric(BYVAL centerX AS WORD, BYVAL centerY AS WORD, BYVAL radius AS WORD, BYVAL colorVal AS BYTE)
    DIM X AS INTEGER, Y AS INTEGER, DecisionParam AS INTEGER
    
    X = 0
    Y = radius
    DecisionParam = 1 - radius
    
    ' Draw initial points
    CALL Svga_PutPixel(centerX, centerY + radius, colorVal)
    CALL Svga_PutPixel(centerX, centerY - radius, colorVal)
    CALL Svga_PutPixel(centerX + radius, centerY, colorVal)
    CALL Svga_PutPixel(centerX - radius, centerY, colorVal)
    
    ' Draw circle using midpoint algorithm
    DO WHILE X < Y
        X = X + 1
        
        IF DecisionParam < 0 THEN
            DecisionParam = DecisionParam + 2 * X + 1
        ELSE
            Y = Y - 1
            DecisionParam = DecisionParam + 2 * (X - Y) + 1
        END IF
        
        ' Draw 8 symmetric points
        CALL Svga_PutPixel(centerX + X, centerY + Y, colorVal)
        CALL Svga_PutPixel(centerX - X, centerY + Y, colorVal)
        CALL Svga_PutPixel(centerX + X, centerY - Y, colorVal)
        CALL Svga_PutPixel(centerX - X, centerY - Y, colorVal)
        CALL Svga_PutPixel(centerX + Y, centerY + X, colorVal)
        CALL Svga_PutPixel(centerX - Y, centerY + X, colorVal)
        CALL Svga_PutPixel(centerX + Y, centerY - X, colorVal)
        CALL Svga_PutPixel(centerX - Y, centerY - X, colorVal)
    LOOP
END SUB

' =============================================================================
' Generic filled circle drawing using HLINE (for modes without optimized circles)
' =============================================================================
SUB Svga_FillCircleGeneric(BYVAL centerX AS WORD, BYVAL centerY AS WORD, BYVAL radius AS WORD, BYVAL colorVal AS BYTE)
    DIM X AS INTEGER, Y AS INTEGER, DecisionParam AS INTEGER
    DIM PrevY AS INTEGER
    
    X = 0
    Y = radius
    DecisionParam = 1 - radius
    PrevY = Y
    
    ' Draw initial horizontal line
    CALL Svga_HLine(centerX - radius, centerX + radius, centerY, colorVal)
    
    ' Fill circle using horizontal lines
    DO WHILE X < Y
        X = X + 1
        
        IF DecisionParam < 0 THEN
            DecisionParam = DecisionParam + 2 * X + 1
        ELSE
            ' Y changed, draw horizontal lines for previous Y
            IF Y <> PrevY THEN
                CALL Svga_HLine(centerX - X + 1, centerX + X - 1, centerY + PrevY, colorVal)
                CALL Svga_HLine(centerX - X + 1, centerX + X - 1, centerY - PrevY, colorVal)
                PrevY = Y
            END IF
            
            Y = Y - 1
            DecisionParam = DecisionParam + 2 * (X - Y) + 1
        END IF
        
        ' Draw horizontal lines for current positions
        CALL Svga_HLine(centerX - Y, centerX + Y, centerY + X, colorVal)
        CALL Svga_HLine(centerX - Y, centerX + Y, centerY - X, colorVal)
    LOOP
    
    ' Draw final lines if Y changed
    IF Y <> PrevY THEN
        CALL Svga_HLine(centerX - X, centerX + X, centerY + Y, colorVal)
        CALL Svga_HLine(centerX - X, centerX + X, centerY - Y, colorVal)
    END IF
END SUB