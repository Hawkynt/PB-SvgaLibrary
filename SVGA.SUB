' =============================================================================
' Draw circle (dispatcher)
' Parameters:
'   CenterX, CenterY - Center coordinates (BYVAL)
'   Radius - Circle radius (BYVAL)
'   colorVal - Circle colorVal (BYVAL)
' Returns: Nothing
' =============================================================================
SUB Svga_DrawCircle(BYVAL centerX AS WORD, BYVAL centerY AS WORD, BYVAL radius AS WORD, BYVAL colorVal AS BYTE)
    ' Use function pointer for ultra-fast dispatch
    IF SVGADispatch.DrawCircle <> 0 THEN
        SELECT CASE VESASystemContext.CurrentMode
            CASE %SVGA_MODEX
            CALL ModeX_DrawCircle(centerX, centerY, radius, colorVal)
            CASE ELSE
            CALL Vga_DrawCircle(centerX, centerY, radius, colorVal)
        END SELECT
    ELSE
        ' VESA doesn't have optimized circle - use generic implementation
        CALL Svga_DrawCircleGeneric(centerX, centerY, radius, colorVal)
    END IF
END SUB

